# Copy to /var/www/yourapp/backend/.env on the VPS (never commit real credentials).
# systemd loads this via EnvironmentFile in deploy/systemd/yourapp.service

DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/payroll_db
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# 32 bytes, urlsafe base64 (generate: python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
ENCRYPTION_MASTER_KEY=GENERATE_AND_STORE_SECURELY

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Artifact storage (bank files)
BANK_FILE_STORAGE_DIR=storage/bank_files
