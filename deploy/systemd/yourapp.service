[Unit]
Description=FastAPI Payroll API (uvicorn)
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/www/yourapp/backend

# Keep secrets out of git: create /var/www/yourapp/backend/.env on the server with DATABASE_URL=...
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-/var/www/yourapp/backend/.env

ExecStart=/var/www/yourapp/venv/bin/uvicorn main:app --host 127.0.0.1 --port 9000

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
